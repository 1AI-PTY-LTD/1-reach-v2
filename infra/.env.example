# Copy to .env.dev and .env.prod, then fill in real values.
# Same UPPER_SNAKE_CASE names as GitHub secrets.
# deploy.sh reads these and passes them as Bicep parameters.

# Azure resource group (not a Bicep param — used by deploy.sh directly)
RESOURCE_GROUP=

# Secrets
DJANGO_SECRET_KEY=
POSTGRES_PASSWORD=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CELERY_BROKER_URL=
AZURE_STORAGE_ACCOUNT_KEY=
WELCORP_PASSWORD=
WELCORP_CALLBACK_SECRET=

# Database
POSTGRES_HOST=
POSTGRES_DB=
POSTGRES_USER=

# Clerk
CLERK_FRONTEND_API=
CLERK_AUTHORIZED_PARTIES=

# Networking
ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_CONTAINER=media

# SMS Provider
SMS_PROVIDER_CLASS=app.utils.welcorp.WelcorpSMSProvider
WELCORP_BASE_URL=https://api.message-service.org/api/v1
WELCORP_USERNAME=
BASE_URL=

# Monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Billing
FREE_CREDIT_AMOUNT=10.00
SMS_RATE=0.10
MMS_RATE=0.50
