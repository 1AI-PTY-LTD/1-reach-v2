# Database
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Backend
DJANGO_SECRET_KEY=
DEBUG=1
TEST=0
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
CLERK_AUTHORIZED_PARTIES=http://localhost:5173

# Clerk
CLERK_FRONTEND_API=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# Storage Provider (optional - defaults to MockStorageProvider)
STORAGE_PROVIDER_CLASS=app.utils.storage.AzureBlobStorageProvider

# Azure Blob Storage (required if using AzureBlobStorageProvider)
AZURE_BLOB_URL=https://<account>.blob.core.windows.net/?<sas-token>
AZURE_CONTAINER=media

# Sentry (optional - disabled if not set)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Logging (optional)
LOG_LEVEL=INFO
LOG_FORMAT=json

# Billing
FREE_CREDIT_AMOUNT=10.00
SMS_RATE=0.05
MMS_RATE=0.20

# Celery (set to Azure Cache for Redis connection string in production)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Database connection pooling (set to 0 to disable; 600 recommended for production)
DB_CONN_MAX_AGE=600

# Security (set to True in production; False locally)
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# Message retry config (optional — these are the defaults)
MESSAGE_MAX_RETRIES=3
MESSAGE_RETRY_BASE_DELAY=60
MESSAGE_RETRY_MAX_DELAY=3600
MESSAGE_RETRY_JITTER=0.25
MESSAGE_PROCESSING_TIMEOUT_MINUTES=30
